ANTHROPIC_API_KEY=sk-ant-...
MODEL=claude-sonnet-4-6
MAX_TOKENS=4000
LOG_LEVEL=INFO

# v2: persistence (SQLite for local dev, Postgres for Docker)
DATABASE_URL=sqlite:///./scoper.db
# DATABASE_URL=postgresql+psycopg2://scoper:scoper@db:5432/scoper

# v2: document ingestion
CHROMA_PERSIST_DIR=./chroma_store
MAX_UPLOAD_SIZE_MB=50
MAX_UPLOAD_FILES=5
